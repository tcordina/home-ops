{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended"],
  "timezone": "Europe/Paris",
  "dependencyDashboard": true,
  "dependencyDashboardTitle": "🤖 Renovate Dashboard",
  "suppressNotifications": ["prEditedNotification"],
  "rebaseWhen": "conflicted",
  "semanticCommits": "enabled",
  "labels": ["dependencies", "renovate"],
  "assigneesFromCodeOwners": true,
  "kubernetes": {
    "managerFilePatterns": ["/^kubernetes/.+\\.yaml$/"]
  },
  "helmfile": {
    "managerFilePatterns": ["/(^|/)helmfile\\.d/.+\\.yaml(?:\\.gotmpl)?$/"]
  },
  "terraform": {
    "managerFilePatterns": ["/infrastructure/terraform/.+\\.tf$"]
  },
  "packageRules": [
    {
      "description": "Auto-merge minor and patch updates",
      "matchUpdateTypes": ["minor", "patch", "pin", "digest"],
      "automerge": true,
      "automergeType": "pr",
      "automergeStrategy": "squash",
      "ignoreTests": true
    },
    {
      "description": "Major updates require manual review",
      "matchUpdateTypes": ["major"],
      "automerge": false,
      "addLabels": ["major-update", "requires-review"]
    },
    {
      "description": "Terraform providers and modules",
      "matchDatasources": ["terraform-provider", "terraform-module"],
      "groupName": "terraform",
      // "group": {
      //   "commitMessageTopic": "{{{groupName}}} group"
      // },
      "commitMessageTopic": "terraform providers"
    },
    {
      "description": "Docker images",
      "matchDatasources": ["docker"],
      "groupName": "docker",
      "commitMessageTopic": "docker images",
      "addLabels": ["kubernentes", "docker"]
    },
    {
      "description": "Helm repositories",
      "matchDatasources": ["helm"],
      "groupName": "helm",
      "commitMessageTopic": "helm repositories",
      "addLabels": ["kubernetes", "helm"]
    },
    {
      "description": "Linuxserver qBittorrent - filter outdated versions",
      "matchDatasources": ["docker"],
      "matchPackageNames": ["linuxserver/qbittorrent"],
      "rangeStrategy": "bump",
      "allowedVersions": "!/^(14|18|20)\\./"
    },
    {
      "description": "Disable updates for unused apps",
      "matchFileNames": ["kubernetes/apps/unused/**"],
      "enabled": false
    }
  ],
  "vulnerabilityAlerts": {
    "enabled": true,
    "labels": ["security"],
    "automerge": false
  },
  "prConcurrentLimit": 10,
  "prHourlyLimit": 0,
  "branchConcurrentLimit": 10
}
