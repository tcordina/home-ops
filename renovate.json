{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended"],
  "timezone": "Europe/Paris",
  "dependencyDashboard": true,
  "dependencyDashboardTitle": "🤖 Renovate Dashboard",
  "suppressNotifications": ["prEditedNotification"],
  "rebaseWhen": "conflicted",
  "semanticCommits": "enabled",
  "labels": ["dependencies", "renovate"],
  "assigneesFromCodeOwners": true,
  "enabledManagers": ["flux", "helmfile", "terraform", "regex"],
  "flux": {
    "managerFilePatterns": ["/^kubernetes/.+\\.yaml$/"]
  },
  "helmfile": {
    "managerFilePatterns": ["/(^|/)helmfile\\.d/.+\\.yaml(?:\\.gotmpl)?$/"]
  },
  "terraform": {
    "managerFilePatterns": ["/infrastructure/terraform/.+\\.tf$"]
  },
  "customManagers": [
    {
      "customType": "regex",
      "description": "Process OCI dependencies",
      "managerFilePatterns": ["/^kubernetes/.+\\.yaml$/"],
      "matchStrings": ["oci://(?<depName>[^:]+):(?<currentValue>\\S+)"],
      "datasourceTemplate": "docker"
    },
    {
      "customType": "regex",
      "description": "Process annotated dependencies",
      "managerFilePatterns": ["/(^|/).+\\.yaml$/"],
      "matchStrings": [
        "renovate: datasource=(?<datasource>\\S+) depName=(?<depName>\\S+)\\n\\s*\\S+:\\s+\\S+/(?<currentValue>[^\\s/]+)",
        "renovate: datasource=(?<datasource>\\S+) depName=(?<depName>\\S+)\\n\\s*\\S+:\\s+(?<currentValue>(?:v|\\d)\\S*)"
      ],
      "datasourceTemplate": "{{datasource}}"
    }
  ],
  "packageRules": [
    {
      "description": "Auto-merge minor and patch updates",
      "matchUpdateTypes": ["minor", "patch", "pin", "digest"],
      "automerge": true,
      "automergeType": "pr",
      "automergeStrategy": "squash",
      "ignoreTests": true
    },
    {
      "description": "Major updates require manual review",
      "matchUpdateTypes": ["major"],
      "automerge": false,
      "labels": ["major-update", "requires-review"]
    },
    {
      "description": "Terraform providers and modules",
      "matchDatasources": ["terraform-provider", "terraform-module"],
      "commitMessageTopic": "terraform dependency : {{depName}}",
      "addLabels": ["terraform"],
      "groupName": "terraform",
      "group": {
        "commitMessageTopic": "{{{groupName}}} dependencies"
      }
    },
    {
      "description": "Docker images",
      "matchDatasources": ["docker"],
      "commitMessageTopic": "docker dependency : {{depName}}",
      "addLabels": ["kubernetes", "docker"],
      "groupName": "docker",
      "group": {
        "commitMessageTopic": "{{{groupName}}} dependencies"
      }
    },
    {
      "description": "Helm repositories",
      "matchDatasources": ["helm"],
      "commitMessageTopic": "helm dependency : {{depName}}",
      "addLabels": ["kubernetes", "helm"],
      "groupName": "helm",
      "group": {
        "commitMessageTopic": "{{{groupName}}} dependencies"
      }
    },
    {
      "description": "OCI Helm charts",
      "matchManagers": ["flux", "helmfile"],
      "matchDatasources": ["docker"],
      "commitMessageTopic": "helm dependency : {{depName}}",
      "labels": ["dependencies", "renovate", "kubernetes", "helm"],
      "groupName": "helm",
      "group": {
        "commitMessageTopic": "{{{groupName}}} dependencies"
      }
    },
    {
      "description": "qBittorrent - filter outdated versions",
      "matchDatasources": ["docker"],
      "matchPackageNames": ["linuxserver/qbittorrent"],
      "rangeStrategy": "bump",
      "allowedVersions": "!/^(14|18|20)\\./"
    },
    {
      "description": "k3s upgrade plan - isolated MR, no automerge",
      "matchDepNames": ["k3s-io/k3s"],
      "matchDatasources": ["github-releases"],
      "groupName": "k3s",
      "automerge": false,
      "labels": ["dependencies", "renovate", "kubernetes", "k3s"]
    },
    {
      "description": "Disable updates for unused apps",
      "matchFileNames": ["kubernetes/apps/unused/**"],
      "enabled": false
    }
  ],
  "vulnerabilityAlerts": {
    "enabled": true,
    "labels": ["security"],
    "automerge": false
  },
  "prConcurrentLimit": 10,
  "prHourlyLimit": 0,
  "branchConcurrentLimit": 10
}
